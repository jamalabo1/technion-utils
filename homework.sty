\makeatletter
\newcommand{\newtheoremenv}[3][\bfseries]{%
    % #1 = formatting (optional, default \bfseries)
    % #2 = environment name
    % #3 = display name
    \newcounter{#2}[question]%
    \expandafter\renewcommand\csname the#2\endcsname{\thesubquestion.\arabic{#2}}%
    \newenvironment{#2}{%
        \refstepcounter{#2}%
        \par\noindent{#1 #3 \csname the#2\endcsname.}%
        \label{\thesubquestion:#2:\arabic{#2}}%
    }{%
        \par%
    }%
}
\makeatother

% Usage with default formatting:
\newtheoremenv{lemma}{Lemma}
\newtheoremenv{claim}{Claim}

% Usage with custom formatting:
\newtheoremenv[\itshape\bfseries]{theorem}{Theorem}

% for local ref's (here l local)
\newcommand{\lref}[1]{%
    \IfRefUndefinedExpandable{\thesubquestion:#1}%
        {\IfRefUndefinedExpandable{#1}%
            {\textbf{??#1??}}%
            {\ref{#1}}%
        }%
        {\ref{\thesubquestion:#1}}%
}
\makeatother

