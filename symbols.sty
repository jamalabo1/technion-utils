\ProvidesPackage{helpers/symbols}[Custom symbols helpers]
\usepackage{xparse}


\usepackage{fontspec}
\usepackage{polyglossia}
% Load font from relative path
\newfontfamily\hebrewfont[
  Path = ../fonts/static/,
  UprightFont = *-Regular.ttf,
  BoldFont = *-Bold.ttf
]{NotoSansHebrew}


\usepackage{amsmath,amsthm,amssymb,hyperref}
\RequirePackage{xcolor}

% Declare options
\newcommand{\R}{\mathbb{R}}  
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\Rp}{\mathbb{R^+}}
\newcommand{\fn}[3][f]{#1\colon#2\to#3}
\newcommand{\ceil}[1]{\lceil #1 \rceil}
\newcommand{\floor}[1]{\lfloor #1 \rfloor}
\newcommand{\F}{\mathbb{F}}
\newcommand{\I}{\mathbb{I}}

\newcommand{\MZ}[1]{\Z_{#1}^{\times}}
\newcommand{\abs}[1]{|#1|}
\newcommand{\norm}[1]{\Vert#1\Vert}


% symbols
\newcommand{\inv}[1]{{#1}^{-1}}
\newcommand{\D}[1]{\cdot{#1}}



\NewDocumentEnvironment{multieq}{m +b} % m = label, +b = body
  {\begin{equation}\label{#1}\begin{split}#2\end{split}\end{equation}}
  {}  % nothing to do at \end{multieq}

\newenvironment{block}
{\begin{flushleft}\setlength{\parskip}{0pt}\setlength{\parindent}{0pt}}
{\end{flushleft}}

\newcounter{question}
\renewcommand{\theequation}{\thequestion.\arabic{equation}}

\newcommand{\newquestion}{
  \newpage
  \stepcounter{question}
  \setcounter{equation}{0}
  \section*{Question \thequestion}
}

\DeclareOption{mathsets} {
     
}
\DeclareOption{functions}{
}
\DeclareOption{limits}{
    \newcommand{\toinf}[1]{#1\to\infty}
}
\DeclareOption{powers}{
    \newcommand{\powW}[2]{#1^{\!^{#2}}}
    \newcommand{\pow}[2]{(#1)^{\!^{#2}}}
}
\DeclareOption{rounding}{
    \newcommand{\ceil}[1]{\lceil #1 \rceil}
    \newcommand{\floor}[1]{\lfloor #1 \rfloor}
}

% Process selected options
\ProcessOptions\relax

